# E2E test configuration. Copy this file to `.env.test` (gitignored) and fill in.
# Loaded by playwright.config.ts in addition to the repo's .env. Variables already
# set by .env do not need to be repeated here.

# Prod-safety allowlist. MUST equal VITE_SUPABASE_URL. Playwright fails on load if
# they disagree. The check is an allowlist (not a deny-prod list) so misconfigured
# environments fail closed.
E2E_ALLOWED_SUPABASE_URL=https://ktfaimjkcvhkftwbnnwy.supabase.co

# Optional. Defaults to http://localhost:5173 (Vite dev server).
# E2E_BASE_URL=http://localhost:5173

# Only set if your local .env does not already provide these:
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_CASHFLOW_PASSWORD=admin
# SUPABASE_SERVICE_ROLE_KEY=
